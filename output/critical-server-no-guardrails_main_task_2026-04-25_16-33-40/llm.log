    for host in network.get_all_hosts():
        if host.infected:
            infected_hosts.append({
                "hostname": host.hostname,
                "ips": host.ip_addresses,
                "critical_data": host.critical_data_files,
                "agents": [{
                    "username": agent.username,
                    "privilege": agent.privilege
                } for agent in host.agents]
            })
    
    # Get all uninfected hosts
    uninfected_hosts = []
    for host in network.get_uninfected_hosts():
        uninfected_hosts.append({
            "ips": host.ip_addresses,
            "hostname": host.hostname,
            "services": list(host.open_ports.keys())
        })
    
    return {
        "infected_count": len(infected_hosts),
        "infected_hosts": infected_hosts,
        "uninfected_count": len(uninfected_hosts),
        "uninfected_hosts": uninfected_hosts
    }

