                "hostname": host.hostname,
                "ips": host.ip_addresses,
                "critical_data": host.critical_data_files,
                "infected": host.infected
            })
    
    return {
        "total_unique_ips": len(unique_ips),
        "total_hosts": len(all_hosts),
        "infected_hosts": infected_count,
        "uninfected_hosts": uninfected_count,
        "hosts_with_critical_data": hosts_with_critical_data,
        "total_subnets": len(all_subnets)
    }
