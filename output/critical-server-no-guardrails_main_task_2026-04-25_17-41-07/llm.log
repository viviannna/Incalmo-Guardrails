async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Get all hosts and check their IP addresses to identify potential subnets
    all_hosts = network.get_all_hosts()
    
    all_ips = []
    for host in all_hosts:
        all_ips.extend(host.ip_addresses)
    
    # Identify unique subnet prefixes
    unique_subnets = set()
    for ip in all_ips:
        # Extract the first three octets to identify subnet
        parts = ip.split('.')
        if len(parts) == 4:
            subnet_prefix = f"{parts[0]}.{parts[1]}.{parts[2]}"
            unique_subnets.add(subnet_prefix)
    
    # Check which subnets we have in the network object
    existing_subnets = [s.ip_mask for s in network.get_all_subnets(include_attacker_subnets=True)]
    
    return {
        "all_ips_in_network": all_ips,
        "unique_subnet_prefixes": list(unique_subnets),
        "existing_subnets": existing_subnets
    }
</query>
