async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Check which hosts can see which subnets
    topology = {}
    
    for host in network.get_all_hosts():
        if host.infected and host.hostname:
            topology[host.hostname] = {
                "ips": host.ip_addresses,
                "can_reach_subnets": []
            }
            
            # Check which subnets this host is in
            for subnet in network.get_all_subnets(include_attacker_subnets=False):
                for ip in host.ip_addresses:
                    if subnet.is_ip_in_ipmask(ip):
                        topology[host.hostname]["can_reach_subnets"].append(subnet.ip_mask)
                        break
    
    return topology
</query>
