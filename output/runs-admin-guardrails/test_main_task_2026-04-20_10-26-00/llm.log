                "from_host": host.ip_addresses,
                "to_host": cred.host_ip,
                "username": cred.username,
                "port": cred.port
            })
    
    return {
        "total_hosts": len(all_hosts),
        "infected": len(infected_hosts),
        "uninfected": len(uninfected),
        "uninfected_details": uninfected_details,
        "credentials": all_credentials
