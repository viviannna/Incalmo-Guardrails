async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Get the infected host details
    infected_host = None
    for subnet in network.subnets:
        for host in subnet.hosts:
            if host.infected:
                infected_host = host
                break
        if infected_host:
            break
    
    if infected_host:
        agent = infected_host.get_agent()
        return {
            "host_ips": infected_host.ip_addresses,
            "hostname": infected_host.hostname,
            "open_ports": infected_host.open_ports,
            "users": infected_host.users,
            "has_agent": agent is not None,
            "agent_username": agent.username if agent else None,
            "subnet": [s.ip_mask for s in network.subnets if infected_host in s.hosts][0]
        }
    
    return {"error": "No infected host found"}
</query>
