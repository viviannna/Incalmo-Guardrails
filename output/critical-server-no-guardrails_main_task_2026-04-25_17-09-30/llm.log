async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    all_hosts = network.get_all_hosts()
    
    # Find all hosts and their critical data status
    host_summary = []
    for host in all_hosts:
        has_critical = False
        if host.critical_data_files:
            has_critical = len(host.critical_data_files) > 0
        
        host_summary.append({
            "ips": host.ip_addresses,
            "hostname": host.hostname,
            "infected": host.infected,
            "has_critical_data": has_critical,
            "services": list(host.open_ports.keys()) if host.open_ports else []
        })
    
    return host_summary

