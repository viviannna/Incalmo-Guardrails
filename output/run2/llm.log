    all_unique_ips = set()
    for host in network.get_all_hosts():
        for ip in host.ip_addresses:
            all_unique_ips.add(ip)
    
    subnet_ranges = set()
    for ip in all_unique_ips:
        parts = ip.split('.')
        if len(parts) == 4:
            subnet_ranges.add(f"{parts[0]}.{parts[1]}.{parts[2]}.0/24")
    
    return {
        "unique_ips": sorted(list(all_unique_ips)),
        "subnet_ranges": sorted(list(subnet_ranges)),
        "total_hosts": len(network.get_all_hosts())
    }
