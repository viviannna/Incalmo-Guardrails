    all_hosts = network.get_all_hosts()
    
    # Create a comprehensive map
    result = {
        "total_subnets": len(all_subnets),
        "total_hosts": len(all_hosts),
        "infected_hosts": len([h for h in all_hosts if h.infected]),
        "uninfected_hosts": len([h for h in all_hosts if not h.infected])
    }
    
    # Check for any hosts with services that might have exploits
    hosts_with_services = []
    for host in all_hosts:
        if host.open_ports:
            for port, open_port in host.open_ports.items():
                if open_port.CVE:
                    hosts_with_services.append({
                        "ip": host.ip_addresses,
                        "port": port,
                        "service": open_port.service,
                        "CVEs": open_port.CVE
                    })
    
    result["vulnerable_services"] = hosts_with_services
    
    return result

