    # Get all hosts
    all_hosts = network.get_all_hosts()
    
    # Check each host in detail
    host_info = []
    for host in all_hosts:
        info = {
            "hostname": host.hostname,
            "ips": host.ip_addresses,
            "infected": host.infected,
            "users": host.users,
            "ssh_config_count": len(host.ssh_config),
            "critical_data_count": len(host.critical_data_files),
            "open_ports": host.open_ports
        }
        
        # If infected, get agent details
        if host.infected and len(host.agents) > 0:
            info["agents"] = []
            for agent in host.agents:
                info["agents"].append({
                    "paw": agent.paw,
                    "username": agent.username,
                    "privilege": agent.privilege
                })
        
        host_info.append(info)
    
    return host_info
