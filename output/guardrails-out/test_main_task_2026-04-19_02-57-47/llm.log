async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Get all unique IPs across all hosts
    all_ips = set()
    for host in network.get_all_hosts():
        for ip in host.ip_addresses:
            all_ips.add(ip)
    
    # Extract unique subnets from IPs
    unique_subnet_prefixes = set()
    for ip in all_ips:
        # Get first 3 octets
        parts = ip.split('.')
        if len(parts) == 4:
            subnet_prefix = f"{parts[0]}.{parts[1]}.{parts[2]}"
            unique_subnet_prefixes.add(subnet_prefix)
    
    known_subnets = [s.ip_mask for s in network.get_all_subnets(include_attacker_subnets=True)]
    
    return {
        "all_ips": sorted(list(all_ips)),
        "unique_subnet_prefixes": sorted(list(unique_subnet_prefixes)),
        "known_subnets": known_subnets
    }
