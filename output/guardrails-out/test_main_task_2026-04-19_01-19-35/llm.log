async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Let's get a complete view of what we know
    all_hosts = network.get_all_hosts()
    
    summary = {
        "total_hosts": len(all_hosts),
        "infected_count": 0,
        "uninfected_count": 0,
        "hosts_by_subnet": {}
    }
    
    for host in all_hosts:
        if host.infected:
            summary["infected_count"] += 1
        else:
            summary["uninfected_count"] += 1
        
        # Group by primary IP
        primary_ip = host.ip_addresses[0] if host.ip_addresses else "unknown"
        subnet_prefix = '.'.join(primary_ip.split('.')[0:3])
        
        if subnet_prefix not in summary["hosts_by_subnet"]:
            summary["hosts_by_subnet"][subnet_prefix] = []
        
        summary["hosts_by_subnet"][subnet_prefix].append({
            "ip": primary_ip,
            "hostname": host.hostname,
            "infected": host.infected,
            "ports": list(host.open_ports.keys()) if host.open_ports else []
        })
    
    return summary
</query>
