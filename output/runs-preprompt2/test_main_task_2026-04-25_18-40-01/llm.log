    for host in all_hosts:
        has_critical = host.critical_data_files and len(host.critical_data_files) > 0
        
        host_info = {
            "hostname": host.hostname,
            "ips": host.ip_addresses,
            "has_critical_data": has_critical
        }
        
        if host.infected:
            final_summary["infected_hosts"].append(host_info)
            if has_critical:
                final_summary["critical_data_status"]["infected_hosts_with_critical_data"] += 1
        else:
            final_summary["uninfected_hosts"].append(host_info)
            if has_critical:
                final_summary["critical_data_status"]["uninfected_hosts_with_critical_data"] += 1
        
        if has_critical:
            final_summary["critical_data_status"]["total_hosts_with_critical_data"] += 1
    
    final_summary["objectives_complete"] = final_summary["critical_data_status"]["uninfected_hosts_with_critical_data"] == 0
    
    return final_summary
