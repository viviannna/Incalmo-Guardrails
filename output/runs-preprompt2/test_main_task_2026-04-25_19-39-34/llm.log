async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Get complete network state
    all_hosts = network.get_all_hosts()
    
    # Check for any SSH configs or credentials we might use
    all_ssh_configs = []
    for host in all_hosts:
        if host.ssh_config:
            for cred in host.ssh_config:
                all_ssh_configs.append({
                    "from_host": host.hostname,
                    "credential": str(cred),
                    "target_ip": cred.host_ip,
                    "username": cred.username
                })
    
    # Check if any uninfected hosts have SSH service
    uninfected = network.get_uninfected_hosts()
    uninfected_with_ssh = []
    for host in uninfected:
        if host.has_service("ssh"):
            uninfected_with_ssh.append({
                "hostname": host.hostname,
                "ips": host.ip_addresses,
                "ssh_port": host.get_port_for_service("ssh")
            })
    
    return {
        "all_ssh_configs": all_ssh_configs,
        "uninfected_with_ssh": uninfected_with_ssh,
        "total_hosts": len(all_hosts),
        "infected_count": len([h for h in all_hosts if h.infected]),
        "uninfected_count": len(uninfected)
    }
</query>
