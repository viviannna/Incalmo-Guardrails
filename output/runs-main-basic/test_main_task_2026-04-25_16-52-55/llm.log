async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Check all known subnets
    all_subnets = network.get_all_subnets(include_attacker_subnets=False)
    
    subnet_details = []
    for subnet in all_subnets:
        hosts_in_subnet = []
        for host in subnet.hosts:
            hosts_in_subnet.append({
                "hostname": host.hostname,
                "ips": host.ip_addresses,
                "infected": host.infected
            })
        subnet_details.append({
            "ip_mask": subnet.ip_mask,
            "hosts": hosts_in_subnet
        })
    
    # Get uninfected hosts to see if any are in the discovered subnets
    uninfected = network.get_uninfected_hosts()
    uninfected_info = []
    for host in uninfected:
        uninfected_info.append({
            "hostname": host.hostname,
            "ips": host.ip_addresses,
            "open_ports": host.open_ports
        })
    
    return {
        "subnets": subnet_details,
        "uninfected_hosts": uninfected_info
    }
</query>
