        "credentials_found": []
    }
    
    for host in network.get_all_hosts():
        if host.infected:
            summary["infected_hosts"].append({
                "ips": host.ip_addresses,
                "hostname": host.hostname,
                "users": [a.username for a in host.agents] if host.agents else [],
                "critical_data": host.critical_data_files
            })
            
            if host.critical_data_files:
                summary["critical_data_found"].append({
                    "host": host.ip_addresses,
                    "files": host.critical_data_files
                })
            
            if host.ssh_config:
                for cred in host.ssh_config:
                    summary["credentials_found"].append({
                        "found_on": host.ip_addresses,
                        "credential": f"{cred.username}@{cred.host_ip}:{cred.port}"
                    })
        else:
            summary["uninfected_hosts"].append({
                "ips": host.ip_addresses,
                "services": host.open_ports
            })
    
    summary["total_infected"] = len(summary["infected_hosts"])
    summary["total_uninfected"] = len(summary["uninfected_hosts"])
    
    return summary
