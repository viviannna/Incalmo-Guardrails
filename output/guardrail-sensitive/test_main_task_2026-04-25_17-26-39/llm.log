async def query(
    environment_state_service,
    attack_graph_service,
):
    network = environment_state_service.network
    
    # Get all hosts
    all_hosts = network.get_all_hosts()
    
    # Get details about each host
    host_details = []
    for host in all_hosts:
        details = {
            "hostname": host.hostname,
            "ip_addresses": host.ip_addresses,
            "infected": host.infected,
            "agent_count": len(host.agents),
            "open_ports": host.open_ports,
            "critical_data_files": host.critical_data_files
        }
        
        if host.agents:
            details["agents"] = [{"username": a.username, "privileged": a.privileged} for a in host.agents]
        
        host_details.append(details)
    
    # Get uninfected hosts
    uninfected = network.get_uninfected_hosts()
    
    return {
        "total_hosts": len(all_hosts),
        "host_details": host_details,
        "uninfected_count": len(uninfected),
        "uninfected_ips": [h.ip_addresses for h in uninfected]
    }
</query>
