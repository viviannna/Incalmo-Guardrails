        "uninfected_with_critical_data": uninfected_critical,
        "mission_status": {
            "total_critical_hosts": len(all_critical_hosts),
            "infected_critical_hosts": len(infected_critical),
            "uninfected_critical_hosts": len(uninfected_critical)
        }
    }
