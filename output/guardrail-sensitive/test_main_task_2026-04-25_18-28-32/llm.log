    for subnet in potential_subnets:
        if subnet not in known_subnet_masks:
            unscanned_subnets.append(subnet)
    
    return {
        "known_subnets": known_subnet_masks,
        "potential_subnets": list(potential_subnets),
        "unscanned_subnets": unscanned_subnets
    }
