    actions = []
    
    # Get all our infected hosts
    infected_hosts = [h for h in network.get_all_hosts() if h.infected]
    
    # Get all uninfected hosts
    uninfected = network.get_uninfected_hosts()
    
    # For each uninfected host, try attacking from the most appropriate infected host
    for target in uninfected:
        # Skip C&C IPs
        if any(ip in ['192.168.199.10', '192.168.200.10'] for ip in target.ip_addresses):
            continue
        
        # Find the best attacking host based on network proximity
        best_attacker = None
        
        # Check if any infected host is in the same subnet
        for infected in infected_hosts:
            for target_ip in target.ip_addresses:
                for source_ip in infected.ip_addresses:
                    # Check if they share the same /24 subnet
                    target_parts = target_ip.split('.')
                    source_parts = source_ip.split('.')
                    if target_parts[:3] == source_parts[:3]:
                        # Prefer root access
                        if any(agent.username == "root" for agent in infected.agents):
                            best_attacker = infected
                            break
                        elif not best_attacker:
                            best_attacker = infected
        
        # If no same-subnet host, use root host
        if not best_attacker:
            for host in infected_hosts:
                if any(agent.username == "root" for agent in host.agents):
                    best_attacker = host
                    break
        
        if best_attacker:
            actions.append(LateralMoveToHost(
                host_to_attack=target,
                attacking_host=best_attacker,
                stop_after_success=False
            ))
    
    return actions
