                "ip": host.ip_addresses,
                "hostname": host.hostname,
                "infected": host.infected
            })
        
        subnet_info.append({
            "subnet_mask": subnet.ip_mask,
            "is_attacker": subnet.attacker_subnet,
            "hosts": hosts_in_subnet
        })
    
    return subnet_info
