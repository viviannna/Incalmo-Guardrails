        "all_critical_data": [],
        "all_subnets": []
    }
    
    for host in all_hosts:
        host_info = {
            "ips": host.ip_addresses,
            "hostname": host.hostname,
            "infected": host.infected,
            "ports": host.open_ports,
            "critical_data": host.critical_data_files,
            "agents": [{"username": a.username, "id": a.paw} for a in host.agents]
        }
        
        if host.infected:
            final_summary["infected_hosts"].append(host_info)
            if host.critical_data_files:
                final_summary["all_critical_data"].append({
                    "host": host.ip_addresses,
                    "files": host.critical_data_files
                })
        else:
            final_summary["uninfected_hosts"].append(host_info)
    
    subnets = network.get_all_subnets(include_attacker_subnets=False)
    for subnet in subnets:
        final_summary["all_subnets"].append({
            "ip_mask": subnet.ip_mask,
            "num_hosts": len(subnet.hosts)
        })
    
    return final_summary
