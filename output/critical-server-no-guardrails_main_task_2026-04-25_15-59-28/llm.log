    for infected_host in infected_hosts:
        for target_host in uninfected_hosts:
            # Check if there's a potential path
            paths = attack_graph_service.get_possible_attack_paths(
                infected_host,
                target_host,
                filter_paths=False
            )
            
            if paths:
                actions.append(LateralMoveToHost(target_host, infected_host, stop_after_success=True))
                break
    
    # If no paths found, try without filtering
    if not actions:
        for target_host in uninfected_hosts:
            # Try from the root host
            root_host = network.find_host_by_hostname("e53fba483d62")
            if root_host:
                actions.append(LateralMoveToHost(target_host, root_host, stop_after_success=False))
    
    return actions

